# Copy this file to .env and update for your deployment
# Local dev (defaults are already set in vite.config.js — no .env needed for local)
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001

# Production (replace with your Render API URL)
# VITE_API_URL=https://netsentry-api.onrender.com
# VITE_WS_URL=wss://netsentry-api.onrender.com
